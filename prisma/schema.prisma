// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrgMemberRole {
  ADMIN
  MAINTAINER
  MEMBER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  HOLD
  COMPLETED
  CANCELLED
}

enum TaskType {
  BUG
  FEATURE
  TASK
  CHANGE
  RESEARCH
  OTHER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  ARCHIVED
}

enum TaskPriority {
  P0
  P1
  P2
  P3
  P4
}

enum InventoryType {
  PERMANENT_ASSET
  CONSUMABLE
  OTHER
}

enum InventoryLogType {
  PROCUREMENT
  LEASE_ASSIGNMENT
  ASSIGNMENT
  RETURN
  USE
  CONSUMPTION
  DESTRUCTION
}

enum TransactionType {
  BUDGET_ADD
  EXPENSE
  REFUND
  ADJUSTMENT
}

enum TransactionScope {
  PROJECT
  TASK
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrgInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum WorkSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  password     String
  status       UserStatus @default(ACTIVE)
  avatar       String?
  isVirtual       Boolean    @default(false) @map("is_virtual")
  mergedIntoId    String?    @map("merged_into_id")
  createdByUserId String?    @map("created_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  lastLogin       DateTime?  @map("last_login")

  orgMemberships        OrgMember[]
  teamMemberships       TeamMember[]
  createdOrgs           Organization[] @relation("OrgCreator")
  createdTeams          Team[]         @relation("TeamCreator")
  createdProjects       Project[]      @relation("ProjectCreator")
  createdTasks          Task[]         @relation("TaskCreator")
  createdWorkLogs       WorkLog[]      @relation("WorkLogCreator")
  createdInventoryItems InventoryItem[]
  createdInventoryLogs  InventoryLog[]
  createdTransactions   Transaction[]
  assignedTasks         Task[]         @relation("TaskAssignee")
  reviewedTasks         Task[]         @relation("TaskReviewer")
  workLogs              WorkLog[]      @relation("WorkLogUser")
  projectUserLinks      ProjectUserLink[]
  inventoryLogUsers     InventoryLogUser[]
  auditLogs             AuditLog[]
  sentInvites           OrgInvite[]    @relation("OrgInviter")
  receivedInvites       OrgInvite[]    @relation("OrgInvitee")
  taskComments          TaskComment[]
  passwordResetTokens   PasswordResetToken[]
  projectDocs           ProjectDoc[]
  virtualProfile        VirtualMemberProfile?
  createdVirtualUsers       User[]                    @relation("VirtualUserCreator")
  createdByUser             User?                     @relation("VirtualUserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  recurringTasksCreated     RecurringTaskTemplate[]   @relation("RecurringCreator")
  recurringTasksAssigned    RecurringTaskTemplate[]   @relation("RecurringAssignee")
  recurringTasksReviewed    RecurringTaskTemplate[]   @relation("RecurringReviewer")
  workSessions              WorkSession[]
  createdJobProfiles        JobProfile[]
  createdJobAds             JobAdvertisement[]
  createdApplicants         Applicant[]
  createdInterviewRounds    InterviewRound[]
  interviewFeedbacks        InterviewFeedback[]
  createdSalaryStructures   SalaryStructure[]
  createdSalaryNegotiations SalaryNegotiation[]
  createdEmploymentOffers   EmploymentOffer[]
  createdHiringBudgets      HiringBudget[]
  interviewRoundInterviewers InterviewRoundInterviewer[]

  @@index([isVirtual])
  @@index([createdByUserId])

  @@map("users")
}

model Organization {
  id           String    @id @default(uuid())
  name         String
  legalName    String   @map("legal_name")
  country      String
  address      String
  contactEmail String   @map("contact_email")
  contactPhone String   @map("contact_phone")
  createdBy    String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  status       OrgStatus @default(ACTIVE)

  creator      User      @relation("OrgCreator", fields: [createdBy], references: [id])
  members      OrgMember[]
  invites      OrgInvite[]
  teams        Team[]
  projects     Project[]
  workLogs     WorkLog[]
  workSessions WorkSession[]
  inventoryItems InventoryItem[]
  inventoryLogs InventoryLog[]
  transactions Transaction[]
  auditLogs          AuditLog[]
  projectDocs        ProjectDoc[]
  recurringTemplates RecurringTaskTemplate[]
  jobProfiles        JobProfile[]
  jobAdvertisements  JobAdvertisement[]
  applicants         Applicant[]
  interviewRounds    InterviewRound[]
  salaryStructures   SalaryStructure[]
  salaryNegotiations SalaryNegotiation[]
  employmentOffers   EmploymentOffer[]
  hiringBudgets      HiringBudget[]

  @@map("organizations")
}

model OrgMember {
  orgId    String        @map("org_id")
  userId   String        @map("user_id")
  role     OrgMemberRole @default(MEMBER)
  joinedAt DateTime      @default(now()) @map("joined_at")

  org      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@map("org_members")
}

model OrgInvite {
  id        String          @id @default(uuid())
  orgId     String          @map("org_id")
  email     String
  role      OrgMemberRole   @default(MEMBER)
  status    OrgInviteStatus @default(PENDING)
  token     String          @unique
  invitedBy String          @map("invited_by")
  expiresAt DateTime        @map("expires_at")
  createdAt DateTime        @default(now()) @map("created_at")
  userId    String?         @map("user_id")

  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter   User            @relation("OrgInviter", fields: [invitedBy], references: [id])
  user      User?           @relation("OrgInvitee", fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("org_invites")
}

model Team {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     User         @relation("TeamCreator", fields: [createdBy], references: [id])
  members     TeamMember[]
  projectLinks ProjectTeamLink[]

  @@unique([orgId, name])
  @@map("teams")
}

model TeamMember {
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     String?
  joinedAt DateTime @default(now()) @map("joined_at")

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

model Project {
  id            String        @id @default(uuid())
  orgId         String        @map("org_id")
  parentId      String?       @map("parent_id")
  name          String
  code          String
  description   String?
  status        ProjectStatus @default(PLANNED)
  startDate     DateTime?     @map("start_date")
  deadline      DateTime?
  costToDate    Decimal       @default(0) @map("cost_to_date") @db.Decimal(15, 2)
  budgetTotal   Decimal?      @map("budget_total") @db.Decimal(15, 2)
  currency      String        @default("INR")
  metadata      Json?         @default("{}")
  createdBy     String        @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent        Project?      @relation("ProjectHierarchy", fields: [parentId], references: [id])
  children      Project[]     @relation("ProjectHierarchy")
  creator       User          @relation("ProjectCreator", fields: [createdBy], references: [id])
  teamLinks     ProjectTeamLink[]
  userLinks     ProjectUserLink[]
  tasks         Task[]
  workLogs      WorkLog[]
  workSessions  WorkSession[]
  inventoryLinks InventoryLink[]
  docs              ProjectDoc[]
  recurringTemplates RecurringTaskTemplate[]

  @@unique([orgId, code])
  @@index([orgId])
  @@index([parentId])
  @@map("projects")
}

model ProjectTeamLink {
  projectId String  @map("project_id")
  teamId    String  @map("team_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([projectId, teamId])
  @@map("project_team_links")
}

model ProjectUserLink {
  projectId String  @map("project_id")
  userId    String  @map("user_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_user_links")
}

model Task {
  id              String        @id @default(uuid())
  projectId       String        @map("project_id")
  parentId        String?       @map("parent_id")
  title           String
  description     String?
  type            TaskType      @default(TASK)
  status          TaskStatus    @default(BACKLOG)
  priority        TaskPriority  @default(P4)
  assignmentDt    DateTime?     @map("assignment_dt")
  startDt         DateTime?     @map("start_dt")
  endDt           DateTime?     @map("end_dt")
  deadlineDt      DateTime?     @map("deadline_dt")
  assigneeUserId  String?       @map("assignee_user_id")
  reviewerUserId  String?       @map("reviewer_user_id")
  estimatedMonths Int?          @map("estimated_months")
  estimatedDays   Int?          @map("estimated_days")
  estimatedHours  Int?          @map("estimated_hours")
  estimatedMinutes Int?         @map("estimated_minutes")
  costOfExecution Decimal?      @map("cost_of_execution") @db.Decimal(15, 2)
  resourceNeeds   Json?         @map("resource_needs")
  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          Task?         @relation("TaskHierarchy", fields: [parentId], references: [id])
  children        Task[]        @relation("TaskHierarchy")
  assignee        User?         @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  reviewer        User?         @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  creator         User          @relation("TaskCreator", fields: [createdBy], references: [id])
  dependencies    TaskDependency[] @relation("BlockedTask")
  blockingTasks   TaskDependency[] @relation("BlockingTask")
  assigneeTransfers TaskAssigneeTransfer[]
  reviewerTransfers TaskReviewerTransfer[]
  tags            TaskTag[]
  workLogs        WorkLog[]
  workSessions    WorkSession[]
  inventoryLinks  InventoryLink[]
  comments        TaskComment[]
  occurrence      RecurringTaskOccurrence?

  @@index([projectId])
  @@index([parentId])
  @@index([assigneeUserId])
  @@index([reviewerUserId])
  @@index([status])
  @@map("tasks")
}

model TaskDependency {
  taskId          String @map("task_id")
  blockedByTaskId String @map("blocked_by_task_id")

  task            Task   @relation("BlockedTask", fields: [taskId], references: [id], onDelete: Cascade)
  blockedByTask   Task   @relation("BlockingTask", fields: [blockedByTaskId], references: [id], onDelete: Cascade)

  @@id([taskId, blockedByTaskId])
  @@map("task_dependencies")
}

model TaskAssigneeTransfer {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  fromUserId String? @map("from_user_id")
  toUserId  String?  @map("to_user_id")
  changedBy String   @map("changed_by")
  reason    String?
  timestamp DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_assignee_transfers")
}

model TaskReviewerTransfer {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  fromUserId String? @map("from_user_id")
  toUserId  String?  @map("to_user_id")
  changedBy String   @map("changed_by")
  reason    String?
  timestamp DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_reviewer_transfers")
}

model TaskTag {
  taskId String @map("task_id")
  tag    String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, tag])
  @@map("task_tags")
}

model TaskComment {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  task        Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments CommentAttachment[]

  @@index([taskId])
  @@index([userId])
  @@map("task_comments")
}

model CommentAttachment {
  id           String   @id @default(uuid())
  commentId    String   @map("comment_id")
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type")
  minioPath    String   @map("minio_path")
  publicUrl    String   @map("public_url")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  comment      TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_attachments")
}

model WorkLog {
  id               String   @id @default(uuid())
  orgId            String   @map("org_id")
  userId           String   @map("user_id")
  createdBy        String   @map("created_by")
  projectId        String?  @map("project_id")
  taskId           String?  @map("task_id")
  totalDurationMin Int      @map("total_duration_min")
  createdAt        DateTime @default(now()) @map("created_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation("WorkLogUser", fields: [userId], references: [id], onDelete: Cascade)
  creator  User         @relation("WorkLogCreator", fields: [createdBy], references: [id])
  project  Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task     Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  segments WorkLogSegment[]

  @@index([orgId])
  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@map("work_logs")
}

model WorkLogSegment {
  id            String   @id @default(uuid())
  workLogId     String   @map("work_log_id")
  startDt       DateTime @map("start_dt")
  endDt         DateTime @map("end_dt")
  durationMin   Int      @map("duration_min")
  comment       String?

  workLog       WorkLog  @relation(fields: [workLogId], references: [id], onDelete: Cascade)

  @@index([workLogId])
  @@map("work_log_segments")
}

model WorkSession {
  id               String             @id @default(uuid())
  orgId            String             @map("org_id")
  projectId        String             @map("project_id")
  taskId           String             @map("task_id")
  userId           String             @map("user_id")
  startDt          DateTime           @map("start_dt")
  completedDt      DateTime?          @map("completed_dt")
  totalDurationMin Int                @default(0) @map("total_duration_min")
  status           WorkSessionStatus  @default(ACTIVE)
  createdAt        DateTime           @default(now()) @map("created_at")

  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task             Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments         WorkSessionSegment[]

  @@index([orgId])
  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("work_sessions")
}

model WorkSessionSegment {
  id          String    @id @default(uuid())
  sessionId   String    @map("session_id")
  startDt     DateTime  @map("start_dt")
  endDt       DateTime? @map("end_dt")
  durationMin Int       @default(0) @map("duration_min")
  createdAt   DateTime  @default(now()) @map("created_at")

  session     WorkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("work_session_segments")
}

model InventoryItem {
  id                      String          @id @default(uuid())
  orgId                   String          @map("org_id")
  name                    String
  details                 String?
  type                    InventoryType  @default(OTHER)
  source                  String?
  batchNo                 String?         @map("batch_no")
  expiryDate              DateTime?       @map("expiry_date")
  warranty                String?
  unitPrice               Decimal         @default(0) @map("unit_price") @db.Decimal(15, 2)
  currency                String          @default("USD")
  annualDepreciationPercent Decimal?      @map("annual_depreciation_percent") @db.Decimal(5, 2)
  serialNo                String?        @map("serial_no")
  quantityCurrent         Int            @default(0) @map("quantity_current")
  createdBy               String          @map("created_by")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  org                     Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator                 User            @relation(fields: [createdBy], references: [id])
  logs                    InventoryLog[]
  links                   InventoryLink[]

  @@index([orgId])
  @@index([type])
  @@map("inventory_items")
}

model InventoryLog {
  id            String            @id @default(uuid())
  orgId         String            @map("org_id")
  inventoryId   String            @map("inventory_id")
  logType       InventoryLogType  @map("log_type")
  datetime      DateTime
  quantity      Int
  notes         String?
  createdBy     String            @map("created_by")
  createdAt     DateTime          @default(now()) @map("created_at")

  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventory     InventoryItem     @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  creator       User              @relation(fields: [createdBy], references: [id])
  users         InventoryLogUser[]
  link          InventoryLink?

  @@index([orgId])
  @@index([inventoryId])
  @@map("inventory_logs")
}

model InventoryLogUser {
  logId  String @map("log_id")
  userId String @map("user_id")

  log    InventoryLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([logId, userId])
  @@map("inventory_log_users")
}

model InventoryLink {
  id          String   @id @default(uuid())
  inventoryId String   @map("inventory_id")
  projectId   String?  @map("project_id")
  taskId      String?  @map("task_id")
  logId       String?  @map("log_id") @unique

  inventory   InventoryItem @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  log         InventoryLog? @relation(fields: [logId], references: [id], onDelete: SetNull)

  @@index([inventoryId])
  @@index([projectId])
  @@index([taskId])
  @@map("inventory_links")
}

model Transaction {
  id        String            @id @default(uuid())
  orgId     String            @map("org_id")
  scope     TransactionScope
  scopeId   String            @map("scope_id")
  type      TransactionType
  amount    Decimal           @db.Decimal(15, 2)
  currency  String            @default("USD")
  datetime  DateTime
  notes     String?
  createdBy String            @map("created_by")
  createdAt DateTime          @default(now()) @map("created_at")

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator   User              @relation(fields: [createdBy], references: [id])

  @@index([orgId])
  @@index([scope, scopeId])
  @@map("transactions")
}

model AuditLog {
  id         String   @id @default(uuid())
  orgId      String?  @map("org_id")
  actorUserId String  @map("actor_user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  diffJson   Json?    @map("diff_json")
  timestamp  DateTime @default(now())

  org        Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actor      User          @relation(fields: [actorUserId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
}

enum DocType {
  LINK
  CREDENTIAL
  NOTE
}

enum DocVisibility {
  MEMBERS
  ADMIN_ONLY
}

enum JobLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  VP
  C_LEVEL
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum JobAdStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicantSource {
  PUBLIC_LINK
  HR_ADDED
  REFERRAL
  AGENCY
}

enum ApplicantStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum InterviewType {
  PHONE_SCREEN
  VIDEO_CALL
  IN_PERSON
  TECHNICAL
  HR_ROUND
  PANEL
  REFERENCE_CHECK
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FeedbackRecommendation {
  STRONG_HIRE
  HIRE
  NEUTRAL
  NO_HIRE
  STRONG_NO_HIRE
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum NegotiationStatus {
  INITIAL
  NEGOTIATING
  AGREED
  REJECTED
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  TEMPLATE
}

model ProjectDoc {
  id          String        @id @default(uuid())
  projectId   String        @map("project_id")
  orgId       String        @map("org_id")
  title       String
  type        DocType       @default(NOTE)
  visibility  DocVisibility @default(MEMBERS)
  content     String?
  url         String?
  metadata    Json?
  sortOrder   Int           @default(0) @map("sort_order")
  createdBy   String        @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     User          @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([orgId])
  @@map("project_docs")
}

model RecurringTaskTemplate {
  id              String               @id @default(uuid())
  projectId       String               @map("project_id")
  orgId           String               @map("org_id")
  title           String
  description     String?
  type            TaskType             @default(TASK)
  priority        TaskPriority         @default(P4)
  assigneeUserId  String?              @map("assignee_user_id")
  reviewerUserId  String?              @map("reviewer_user_id")
  frequency       RecurrenceFrequency
  startDate       DateTime             @map("start_date")
  endDate         DateTime?            @map("end_date")
  isActive        Boolean              @default(true) @map("is_active")
  createdBy       String               @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  lastGeneratedAt DateTime?            @map("last_generated_at")

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  org             Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator         User                 @relation("RecurringCreator", fields: [createdBy], references: [id])
  assignee        User?                @relation("RecurringAssignee", fields: [assigneeUserId], references: [id])
  reviewer        User?                @relation("RecurringReviewer", fields: [reviewerUserId], references: [id])
  occurrences     RecurringTaskOccurrence[]

  @@index([projectId])
  @@index([orgId])
  @@map("recurring_task_templates")
}

model RecurringTaskOccurrence {
  id          String                @id @default(uuid())
  templateId  String                @map("template_id")
  taskId      String                @unique @map("task_id")
  periodStart DateTime              @map("period_start")
  periodEnd   DateTime              @map("period_end")
  createdAt   DateTime              @default(now()) @map("created_at")

  template    RecurringTaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  task        Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("recurring_task_occurrences")
}

model VirtualMemberProfile {
  userId       String    @id @map("user_id")
  phone        String?
  whatsapp     String?
  address      String?
  githubUrl    String?   @map("github_url")
  linkedinUrl  String?   @map("linkedin_url")
  dob          DateTime? @map("dob") @db.Date
  parentOrg    String?   @map("parent_org")
  designation  String?
  education    String?
  introducedBy String?   @map("introduced_by")
  bankAccount     String?   @map("bank_account")
  upiId           String?   @map("upi_id")
  fieldVisibility Json?     @map("field_visibility")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("virtual_member_profiles")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model JobProfile {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  title                 String
  code                  String
  department            String?
  level                 JobLevel
  employmentType        EmploymentType
  description           String?
  responsibilities      Json?
  requirements          Json?
  niceToHave            Json?
  minExperienceYears    Int?          @map("min_experience_years")
  maxExperienceYears    Int?          @map("max_experience_years")
  skills                Json?
  educationLevel        String?       @map("education_level")
  isActive              Boolean       @default(true) @map("is_active")
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator               User          @relation(fields: [createdBy], references: [id])
  advertisements        JobAdvertisement[]
  applicants            Applicant[]
  hiringBudgets         HiringBudget[]
  offers                EmploymentOffer[]

  @@unique([orgId, code])
  @@index([orgId])
  @@map("job_profiles")
}

model JobAdvertisement {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  jobProfileId          String        @map("job_profile_id")
  title                 String
  adContent             String        @map("ad_content")
  aiProvider            AIProvider    @default(TEMPLATE) @map("ai_provider")
  aiModifications       String?       @map("ai_modifications")
  publicToken           String        @unique @map("public_token")
  status                JobAdStatus   @default(DRAFT)
  deadline              DateTime?
  location              String?
  isRemote              Boolean       @default(false) @map("is_remote")
  salaryRangeMin        Decimal?      @map("salary_range_min") @db.Decimal(15, 2)
  salaryRangeMax        Decimal?      @map("salary_range_max") @db.Decimal(15, 2)
  salaryCurrency        String        @default("INR") @map("salary_currency")
  showSalary            Boolean       @default(false) @map("show_salary")
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobProfile            JobProfile    @relation(fields: [jobProfileId], references: [id], onDelete: Cascade)
  creator               User          @relation(fields: [createdBy], references: [id])
  applicants            Applicant[]
  offers                EmploymentOffer[] @relation("AdvertisementOffer")

  @@index([orgId])
  @@index([jobProfileId])
  @@index([publicToken])
  @@index([status])
  @@map("job_advertisements")
}

model Applicant {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  jobProfileId          String?       @map("job_profile_id")
  advertisementId       String?       @map("advertisement_id")
  firstName             String        @map("first_name")
  lastName              String        @map("last_name")
  email                 String
  phone                 String?
  alternatePhone        String?       @map("alternate_phone")
  linkedinUrl           String?       @map("linkedin_url")
  githubUrl             String?       @map("github_url")
  portfolioUrl          String?       @map("portfolio_url")
  otherLinks            Json?         @map("other_links")
  city                  String?
  country               String?
  address               String?
  cvMinioPath           String?       @map("cv_minio_path")
  cvPublicUrl           String?       @map("cv_public_url")
  cvFileName            String?       @map("cv_file_name")
  cvFileSize            Int?          @map("cv_file_size")
  currentCompany        String?       @map("current_company")
  currentTitle          String?       @map("current_title")
  currentSalary         Decimal?      @map("current_salary") @db.Decimal(15, 2)
  currentCurrency       String        @default("INR") @map("current_currency")
  noticePeriodDays      Int?          @map("notice_period_days")
  expectedSalaryMin     Decimal?      @map("expected_salary_min") @db.Decimal(15, 2)
  expectedSalaryMax     Decimal?      @map("expected_salary_max") @db.Decimal(15, 2)
  expectedCurrency      String        @default("INR") @map("expected_currency")
  source                ApplicantSource @default(HR_ADDED)
  referredBy            String?       @map("referred_by")
  status                ApplicantStatus @default(NEW)
  internalNotes         String?       @map("internal_notes")
  appliedAt             DateTime      @default(now()) @map("applied_at")
  createdBy             String?       @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobProfile            JobProfile?   @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  advertisement         JobAdvertisement? @relation(fields: [advertisementId], references: [id], onDelete: SetNull)
  creator               User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  educations            ApplicantEducation[]
  experiences           ApplicantExperience[]
  interviewRounds       InterviewRound[]
  salaryStructures      SalaryStructure[]
  salaryNegotiations    SalaryNegotiation[]
  offers                EmploymentOffer[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([jobProfileId])
  @@index([advertisementId])
  @@index([status])
  @@map("applicants")
}

model ApplicantEducation {
  id                    String        @id @default(uuid())
  applicantId           String        @map("applicant_id")
  degree                String
  institution           String
  fieldOfStudy          String?       @map("field_of_study")
  startYear             Int?          @map("start_year")
  endYear               Int?          @map("end_year")
  grade                 String?
  isCurrent             Boolean       @default(false) @map("is_current")

  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@map("applicant_educations")
}

model ApplicantExperience {
  id                    String        @id @default(uuid())
  applicantId           String        @map("applicant_id")
  company               String
  title                 String
  startDate             DateTime?     @map("start_date")
  endDate               DateTime?     @map("end_date")
  isCurrent             Boolean       @default(false) @map("is_current")
  description           String?

  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@map("applicant_experiences")
}

model InterviewRound {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  applicantId           String        @map("applicant_id")
  roundNumber           Int           @map("round_number")
  type                  InterviewType
  status                InterviewStatus @default(SCHEDULED)
  scheduledAt           DateTime?     @map("scheduled_at")
  completedAt           DateTime?     @map("completed_at")
  durationMin           Int?          @map("duration_min")
  meetingLink           String?       @map("meeting_link")
  location              String?
  agenda                String?
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  creator               User          @relation(fields: [createdBy], references: [id])
  interviewers          InterviewRoundInterviewer[]
  feedbacks             InterviewFeedback[]

  @@index([orgId])
  @@index([applicantId])
  @@index([status])
  @@map("interview_rounds")
}

model InterviewRoundInterviewer {
  roundId               String        @map("round_id")
  userId                String        @map("user_id")

  round                 InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roundId, userId])
  @@map("interview_round_interviewers")
}

model InterviewFeedback {
  id                    String        @id @default(uuid())
  roundId               String        @map("round_id")
  userId                String        @map("user_id")
  recommendation        FeedbackRecommendation
  technicalScore        Int?          @map("technical_score")
  communicationScore    Int?          @map("communication_score")
  problemSolvingScore   Int?          @map("problem_solving_score")
  cultureScore          Int?          @map("culture_score")
  overallScore          Int?          @map("overall_score")
  strengths             String?
  weaknesses            String?
  notes                 String?
  isSubmitted           Boolean       @default(false) @map("is_submitted")
  submittedAt           DateTime?     @map("submitted_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  round                 InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  interviewer           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId])
  @@map("interview_feedbacks")
}

model SalaryStructure {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  applicantId           String        @map("applicant_id")
  baseSalary            Decimal       @map("base_salary") @db.Decimal(15, 2)
  currency              String        @default("USD")
  variablePay           Decimal?      @map("variable_pay") @db.Decimal(15, 2)
  signingBonus          Decimal?      @map("signing_bonus") @db.Decimal(15, 2)
  stockOptions          Decimal?      @map("stock_options") @db.Decimal(15, 2)
  annualLeave           Int?          @map("annual_leave")
  otherBenefits         Json?         @map("other_benefits")
  workingHoursPerWeek   Int?          @map("working_hours_per_week")
  workLocation          String?       @map("work_location")
  specialConsiderations String?       @map("special_considerations")
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  creator               User          @relation(fields: [createdBy], references: [id])
  negotiations          SalaryNegotiation[]
  offers                EmploymentOffer[]

  @@index([orgId])
  @@index([applicantId])
  @@map("salary_structures")
}

model SalaryNegotiation {
  id                    String        @id @default(uuid())
  salaryStructureId     String        @map("salary_structure_id")
  applicantId           String        @map("applicant_id")
  orgId                 String        @map("org_id")
  roundNumber           Int           @map("round_number")
  proposedByApplicant   Boolean       @map("proposed_by_applicant")
  proposedBaseSalary    Decimal?      @map("proposed_base_salary") @db.Decimal(15, 2)
  proposedVariable      Decimal?      @map("proposed_variable") @db.Decimal(15, 2)
  notes                 String?
  status                NegotiationStatus
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  respondedAt           DateTime?     @map("responded_at")

  salaryStructure       SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)
  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator               User          @relation(fields: [createdBy], references: [id])

  @@index([salaryStructureId])
  @@index([applicantId])
  @@index([orgId])
  @@map("salary_negotiations")
}

model EmploymentOffer {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  applicantId           String        @map("applicant_id")
  salaryStructureId     String        @map("salary_structure_id")
  jobProfileId          String?       @map("job_profile_id")
  advertisementId       String?       @map("advertisement_id")
  status                OfferStatus   @default(DRAFT)
  offerMinioPath        String?       @map("offer_minio_path")
  offerPublicUrl        String?       @map("offer_public_url")
  offerFileName         String?       @map("offer_file_name")
  assignedRole          OrgMemberRole @default(MEMBER) @map("assigned_role")
  sentAt                DateTime?     @map("sent_at")
  expiresAt             DateTime?     @map("expires_at")
  acceptedAt            DateTime?     @map("accepted_at")
  declinedAt            DateTime?     @map("declined_at")
  declineReason         String?       @map("decline_reason")
  joiningDate           DateTime?     @map("joining_date")
  joiningConfirmed      Boolean       @default(false) @map("joining_confirmed")
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant             Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  salaryStructure       SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)
  jobProfile            JobProfile?   @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  advertisement         JobAdvertisement? @relation("AdvertisementOffer", fields: [advertisementId], references: [id], onDelete: SetNull)
  creator               User          @relation(fields: [createdBy], references: [id])

  @@index([orgId])
  @@index([applicantId])
  @@index([status])
  @@map("employment_offers")
}

model HiringBudget {
  id                    String        @id @default(uuid())
  orgId                 String        @map("org_id")
  jobProfileId          String?       @map("job_profile_id")
  fiscalYear            Int           @map("fiscal_year")
  department            String
  budgetedPositions     Int           @map("budgeted_positions")
  filledPositions       Int           @default(0) @map("filled_positions")
  allocatedAmount       Decimal       @map("allocated_amount") @db.Decimal(15, 2)
  spentAmount           Decimal       @default(0) @map("spent_amount") @db.Decimal(15, 2)
  currency              String        @default("USD")
  notes                 String?
  createdBy             String        @map("created_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobProfile            JobProfile?   @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  creator               User          @relation(fields: [createdBy], references: [id])

  @@index([orgId])
  @@index([jobProfileId])
  @@map("hiring_budgets")
}
